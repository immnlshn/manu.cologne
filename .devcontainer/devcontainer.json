{
  "name": "Node.js & TypeScript",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:4-24-trixie",
  "features": {
    "ghcr.io/devcontainers-extra/features/pnpm:2": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/${localWorkspaceFolderBasename},type=bind,consistency=cached,relabel=shared",
  "runArgs": [
    "--userns=keep-id"
  ],
  "remoteUser": "node",
  "postCreateCommand": "pnpm install && gh auth setup-git",
  "forwardPorts": [
    5173,
    3000
  ],
  "customizations": {
    "jetbrains": {
      "backend": "IU",
      "plugins": []
    }
  }
}
